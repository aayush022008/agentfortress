      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 80}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "Active Sessions",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "agentshield_active_sessions", "legendFormat": "Sessions"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "id": 2,
      "title": "Total Alerts",
      "type": "stat",
      "targets": [{"expr": "sum(agentshield_alerts_total)", "legendFormat": "Alerts"}],
